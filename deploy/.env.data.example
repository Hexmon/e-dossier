# Base data VM template. Copy this to deploy/.env.data and replace secrets/origins per environment.
# Postgres
POSTGRES_DB=e_dossier_v2
POSTGRES_USER=edossier
POSTGRES_PASSWORD=change_me_strong
POSTGRES_PORT=5432

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_strong
MINIO_REGION=us-east-1
MINIO_BUCKET=oc-images
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
# Dev default below. In QA/production, replace with the browser-visible VM-1 app origin,
# for example http://<VM1-IP> or https://app.example.
MINIO_API_CORS_ALLOW_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
