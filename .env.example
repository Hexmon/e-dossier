# Base template. Prefer .env.development.example / .env.qa.example / .env.production.example
DATABASE_URL=postgresql://postgres:REPLACE_WITH_DB_PASSWORD@localhost:5432/e_dossier_v2
ACCESS_TOKEN_PRIVATE_KEY=REPLACE_WITH_PKCS8_PRIVATE_KEY_PEM_ESCAPED
ACCESS_TOKEN_PUBLIC_KEY=REPLACE_WITH_SPKI_PUBLIC_KEY_PEM_ESCAPED
ACCESS_TOKEN_TTL_SECONDS=900
CSRF_SECRET=REPLACE_WITH_STRONG_RANDOM_CSRF_SECRET
NODE_ENV=development
EXPOSE_TOKENS_IN_DEV=false
NEXT_PUBLIC_API_BASE_URL=http://172.22.128.57

# Super Admin (post: SUPER_ADMIN)
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=REPLACE_WITH_STRONG_SUPERADMIN_PASSWORD
SUPERADMIN_EMAIL=superadmin@example.com
SUPERADMIN_PHONE=+910000000000
SUPERADMIN_NAME=Super Admin
SUPERADMIN_RANK=SUPER

# Admin (post: ADMIN)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=REPLACE_WITH_STRONG_ADMIN_PASSWORD
ADMIN_EMAIL=admin@example.com
ADMIN_PHONE=+910000000001
ADMIN_NAME=Admin
ADMIN_RANK=ADMIN

## Seeding admin accounts

# With the above env vars set (or in a .env file), run `pnpm seed:admins` to create/update the SUPER_ADMIN and ADMIN users, their credentials, positions, and active appointments.

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=10.0.0.20
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=REPLACE_WITH_STRONG_MINIO_SECRET_KEY
MINIO_BUCKET=oc-images
MINIO_REGION=us-east-1
# Optional: public base URL (CDN or reverse proxy path)
MINIO_PUBLIC_URL=https://your-domain.example/media

# ============================================
# Rate Limiting Configuration
# ============================================
# Global rate limit enable/disable
# Set to 'true' to enable rate limiting, 'false' to disable (default: false for local dev)
RATE_LIMIT_ENABLED=false

# API rate limiting (general endpoints)
# Max requests per time window
RATE_LIMIT_API_MAX_REQUESTS=100
# Time window in seconds
RATE_LIMIT_API_WINDOW_SECONDS=60

# Login rate limiting
RATE_LIMIT_LOGIN_MAX_REQUESTS=5
RATE_LIMIT_LOGIN_WINDOW_SECONDS=900

# Signup rate limiting
RATE_LIMIT_SIGNUP_MAX_REQUESTS=3
RATE_LIMIT_SIGNUP_WINDOW_SECONDS=3600

# Password reset rate limiting
RATE_LIMIT_PASSWORD_RESET_MAX_REQUESTS=3
RATE_LIMIT_PASSWORD_RESET_WINDOW_SECONDS=3600

# Optional: Redis key prefix for rate limiting
RATE_LIMIT_REDIS_KEY_PREFIX=ratelimit

# Optional: Exclude health check endpoint from rate limiting
RATE_LIMIT_EXCLUDE_HEALTH_CHECK=true

# Optional: Upstash Redis (rate limiting)
# Leave empty to use in-memory rate limiting (dev only)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Authorization V2 (feature-flagged rollout)
AUTHZ_V2_ENABLED=false
NEXT_PUBLIC_AUTHZ_V2_ENABLED=false
AUTHZ_V2_CACHE_TTL_MS=30000
